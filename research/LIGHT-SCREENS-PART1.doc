  bg-surface:         #F0EAFC   (Surface — section headers, insets, tracks)
  bg-card:            #EDE5F7   (Card Surface — elevated containers when needed)
  bg-white:           #FFFFFF   (Pure white — cards, sheets, inputs)
  bg-gold-wash:       #FFF8E1   (Gold Wash — highlight, selected states)

  Text Hierarchy
  --------------
  text-primary:       #1A0533   (Midnight Purple — 17.51:1 on #F8F5FF)
  text-secondary:     #6B21A8   (Deep Violet — 8.2:1 on #F8F5FF)
  text-tertiary:      #475569   (Slate Gray — 6.1:1 on #F8F5FF)
  text-disabled:      #94A3B8   (Light Slate — 3.8:1, decorative only)
  text-on-gold:       #FFFFFF   (White on gold — 4.8:1 on #B8860B)
  text-on-purple:     #FFFFFF   (White on purple fills)
  text-on-white:      #1A0533   (Primary on white cards)

  Brand Colors
  ------------
  brand-gold:         #B8860B   (Dark Goldenrod — primary CTA)
  brand-gold-hover:   #A07608   (Darker gold for hover/press)
  brand-gold-light:   #D4A017   (Lighter gold for decorative)
  brand-violet:       #6B21A8   (Deep Violet — secondary accent)
  brand-violet-light: #8B5CF6   (Light Violet — links, interactive)
  brand-purple-deep:  #3B0764   (Deepest purple — rare emphasis)

  Semantic Colors
  ---------------
  semantic-success:   #059669   (Emerald — completion)
  semantic-warning:   #D97706   (Amber — P2, caution)
  semantic-error:     #E11D48   (Rose — destructive, overdue)
