  buckets: [0.1, 0.5, 1, 2, 5, 10, 30, 60, 120],
});

const notificationEndToEndHistogram = new Histogram({
  name: 'unjynx_notification_e2e_latency_seconds',
  help: 'Time from scheduled time to delivery confirmation',
  labelNames: ['channel'],
  buckets: [1, 5, 10, 30, 60, 120, 300, 600, 1800, 3600],
});

// Gauges
const queueDepthGauge = new Gauge({
  name: 'unjynx_notification_queue_depth',
  help: 'Current number of jobs waiting in queue',
  labelNames: ['channel', 'state'],  // state: waiting, active, delayed, failed
});

const channelHealthGauge = new Gauge({
  name: 'unjynx_channel_health',
  help: 'Channel health score (0=down, 1=degraded, 2=healthy)',
  labelNames: ['channel'],
});

const dailyCostGauge = new Gauge({
  name: 'unjynx_notification_daily_cost_paise',
  help: 'Running total cost for today in paise',
