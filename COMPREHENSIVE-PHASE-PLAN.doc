  labelNames: ['from_channel', 'to_channel', 'error_type'],
});

const notificationsDeadLetterCounter = new Counter({
  name: 'unjynx_notifications_dead_letter_total',
  help: 'Notifications that ended in dead letter queue',
  labelNames: ['reason'],
});

const notificationCostCounter = new Counter({
  name: 'unjynx_notification_cost_paise_total',
  help: 'Total notification cost in paise (1/100 INR)',
