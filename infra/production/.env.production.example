# ─────────────────────────────────────────────────────────────────────────────
# UNJYNX Production Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
#
# INSTRUCTIONS:
#   1. Copy this file to .env.production
#   2. Fill in all values (no defaults are safe for production)
#   3. NEVER commit .env.production to version control
#   4. Use a secret manager (Doppler, Vault, etc.) for production deployments
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000
LOG_LEVEL=info
# Unique instance ID for distributed tracing
INSTANCE_ID=

# ── Database (Neon free tier or self-hosted PostgreSQL 16+) ──────────────────

DATABASE_URL=postgresql://user:password@host:5432/unjynx
# Connection pool settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_SSL=true

# ── Cache & Queue (Upstash or self-hosted Valkey/Redis) ──────────────────────

REDIS_URL=redis://default:password@host:6379
REDIS_TLS=true
# BullMQ queue prefix (isolate environments sharing same Redis)
QUEUE_PREFIX=unjynx:prod

# ── Authentication (Logto - self-hosted OIDC) ───────────────────────────────

LOGTO_ENDPOINT=https://auth.unjynx.com
LOGTO_APP_ID=
LOGTO_APP_SECRET=
# Logto M2M credentials for backend-to-backend calls
LOGTO_M2M_APP_ID=
LOGTO_M2M_APP_SECRET=
# JWT signing key (RS256 public key from Logto)
JWT_ISSUER=https://auth.unjynx.com/oidc

# ── Object Storage (Cloudflare R2 - S3 compatible) ──────────────────────────

S3_ENDPOINT=https://account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=unjynx-uploads
S3_REGION=auto
# Public CDN URL for serving uploaded files
S3_PUBLIC_URL=https://cdn.unjynx.com

# ── Email (Resend - transactional email) ────────────────────────────────────

RESEND_API_KEY=
EMAIL_FROM=UNJYNX <noreply@unjynx.com>
EMAIL_REPLY_TO=support@unjynx.com

# ── AI (Claude API via Anthropic) ───────────────────────────────────────────

AI_BASE_URL=https://api.anthropic.com/v1
AI_API_KEY=
# Model distribution: Haiku 80%, Sonnet 15%, Opus 5%
AI_MODEL_DEFAULT=claude-haiku-4-5-20251001
AI_MODEL_COMPLEX=claude-sonnet-4-6-20260310
AI_MODEL_REASONING=claude-opus-4-6-20260310
# Monthly AI budget cap (USD) - hard limit
AI_BUDGET_CAP=500

# ── Push Notifications (Firebase Cloud Messaging) ───────────────────────────

FCM_PROJECT_ID=
# Base64-encoded service account JSON
FCM_SERVICE_ACCOUNT_KEY=

# ── Telegram Bot ────────────────────────────────────────────────────────────

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ── WhatsApp (Gupshup BSP) ─────────────────────────────────────────────────

WHATSAPP_GUPSHUP_API_KEY=
WHATSAPP_GUPSHUP_APP_NAME=
WHATSAPP_GUPSHUP_SOURCE_NUMBER=
WHATSAPP_WEBHOOK_SECRET=

# ── SMS (MSG91 - India) ────────────────────────────────────────────────────

SMS_MSG91_AUTH_KEY=
SMS_MSG91_SENDER_ID=UNJYNX
SMS_MSG91_DLT_TE_ID=

# ── Instagram (Messenger Platform API) ──────────────────────────────────────

INSTAGRAM_PAGE_ACCESS_TOKEN=
INSTAGRAM_APP_SECRET=
INSTAGRAM_VERIFY_TOKEN=

# ── Slack Integration ───────────────────────────────────────────────────────

SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ── Discord Integration ────────────────────────────────────────────────────

DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# ── Payments (RevenueCat) ──────────────────────────────────────────────────

REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_SECRET=
# Apple App Store
APPLE_SHARED_SECRET=
# Google Play
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY=

# ── Monitoring & Error Tracking ─────────────────────────────────────────────

# Sentry (error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# PostHog (product analytics)
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# Grafana Cloud (metrics & logs)
GRAFANA_CLOUD_API_KEY=
GRAFANA_CLOUD_PROMETHEUS_URL=
GRAFANA_CLOUD_LOKI_URL=

# ── Security ────────────────────────────────────────────────────────────────

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://unjynx.com,https://www.unjynx.com,https://admin.unjynx.com
# API request signing secret (for mobile app request integrity)
API_SIGNING_SECRET=
# Encryption key for sensitive data at rest (AES-256)
DATA_ENCRYPTION_KEY=

# ── Feature Flags ───────────────────────────────────────────────────────────

# Enable/disable features without deployment
FEATURE_AI_CHAT=false
FEATURE_INDUSTRY_MODES=false
FEATURE_TEAM_FEATURES=false
FEATURE_GHOST_MODE=true
FEATURE_CONTENT_DELIVERY=true
