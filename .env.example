# =============================================================================
# TODO Reminder App - Environment Variables
# =============================================================================
# Copy this file to .env and customize as needed.
# All values below are safe defaults for local development.
# =============================================================================

# --- Database (PostgreSQL) ---
POSTGRES_USER=todoapp
POSTGRES_PASSWORD=todoapp_dev_password
POSTGRES_DB=todoapp
DATABASE_URL=postgresql://todoapp:todoapp_dev_password@localhost:5432/todoapp

# --- Redis (Valkey) ---
REDIS_URL=redis://localhost:6379

# --- Auth (Logto) ---
LOGTO_ENDPOINT=http://localhost:3001
LOGTO_ADMIN_ENDPOINT=http://localhost:3002
# These are set after creating an app in Logto admin console:
# LOGTO_APP_ID=
# LOGTO_APP_SECRET=

# --- File Storage (MinIO / S3-compatible) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=todo-uploads
S3_REGION=us-east-1

# --- Email (Mailpit locally, Resend in production) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# Production: RESEND_API_KEY=re_xxxx

# --- AI / LLM ---
AI_BASE_URL=http://localhost:11434/v1
AI_API_KEY=ollama
AI_MODEL=llama3.2:3b
# Production:
# AI_BASE_URL=https://api.anthropic.com/v1
# AI_API_KEY=sk-ant-xxxx
# AI_MODEL=claude-3-5-haiku-20241022

# --- Notifications ---
# Telegram (free, create bot via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# WhatsApp (Meta Cloud API - free test mode)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Push (Firebase Cloud Messaging - free)
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_KEY=

# --- Monitoring ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# --- Error Tracking (Sentry) ---
# Get DSN from sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- Backend Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# --- pgAdmin ---
PGADMIN_EMAIL=admin@todo.local
PGADMIN_PASSWORD=admin
