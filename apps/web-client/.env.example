# ===========================================================================
# UNJYNX Web Client - Environment Variables
# ===========================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local — it is git-ignored.
# ===========================================================================

# ── Backend API ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.unjynx.me/api/v1

# ── Logto OIDC ────────────────────────────────────────────────────────────
NEXT_PUBLIC_LOGTO_ENDPOINT=https://auth.unjynx.me
NEXT_PUBLIC_LOGTO_APP_ID=unjynx-web-client

# ── WebSocket (future) ────────────────────────────────────────────────────
NEXT_PUBLIC_WS_URL=wss://api.unjynx.me/ws
