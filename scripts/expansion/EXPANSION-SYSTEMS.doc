### 3.7 BULLMQ JOB DESIGN

JOB DATA STRUCTURE:

```typescript
interface NotificationJobData {
  notificationId: string;
  deliveryAttemptId: string;
  userId: string;
  channel: NotificationChannel;
  
  // Content (resolved at queue time, not at process time)
  title: string;
  body: string;
  actionUrl?: string;
  
  // Channel-specific payload
  channelPayload: {
    // For Push:
    fcmToken?: string;
    androidChannelId?: string;
    badge?: number;
    sound?: string;
    data?: Record<string, string>;
    
    // For Telegram:
    chatId?: string;
    parseMode?: 'HTML' | 'Markdown';
    replyMarkup?: object;   // Inline keyboard for actions
    
    // For WhatsApp:
    phoneNumber?: string;
    templateName?: string;
    templateLanguage?: string;
    templateParams?: string[];
    
    // For Email:
    to?: string;
    from?: string;
    templateId?: string;
    dynamicData?: Record<string, unknown>;
    
    // For SMS:
    phoneNumber?: string;
    senderId?: string;
    templateId?: string;   // DLT template ID (India regulation)
  };
  
  // Cascade context
  cascadeId: string;
  cascadeOrder: number;
  originalChannel?: NotificationChannel;  // The channel that was tried first
  
  // Metadata
  notificationType: NotificationType;
  priority: number;
  taskId?: string;
  contentId?: string;
}
```

JOB PRIORITY LEVELS:

```typescript
// BullMQ priority: lower number = higher priority
const JOB_PRIORITIES = {
  CRITICAL: 1,      // System alerts, security notifications
  HIGH: 3,          // Urgent task reminders (priority: urgent, due in <1h)
  NORMAL: 5,        // Standard task reminders
  LOW: 7,           // Daily content, non-urgent reminders
  BULK: 10,         // Announcements, marketing, batch operations
} as const;
```

QUEUE SETUP:

```typescript
import { Queue, Worker, QueueEvents, FlowProducer } from 'bullmq';

const createNotificationQueues = (redis: IORedis) => {
  const queues: Record<NotificationChannel, Queue> = {
    push: new Queue('notification:push', {
      connection: redis,
      defaultJobOptions: {
        ...QUEUE_CONFIG['notification:push'],
        priority: JOB_PRIORITIES.NORMAL,
      },
    }),
    telegram: new Queue('notification:telegram', {
      connection: redis,
      defaultJobOptions: {
        ...QUEUE_CONFIG['notification:telegram'],
        priority: JOB_PRIORITIES.NORMAL,
      },
    }),
    whatsapp: new Queue('notification:whatsapp', {
      connection: redis,
      defaultJobOptions: {
        ...QUEUE_CONFIG['notification:whatsapp'],
        priority: JOB_PRIORITIES.NORMAL,
      },
    }),
    email: new Queue('notification:email', {
      connection: redis,
      defaultJobOptions: {
        ...QUEUE_CONFIG['notification:email'],
        priority: JOB_PRIORITIES.NORMAL,
      },
    }),
    sms: new Queue('notification:sms', {
      connection: redis,
      defaultJobOptions: {
        ...QUEUE_CONFIG['notification:sms'],
        priority: JOB_PRIORITIES.NORMAL,
      },
    }),
    in_app: new Queue('notification:in_app', {
      connection: redis,
      defaultJobOptions: {
        attempts: 1,
        timeout: 5000,
        removeOnComplete: { age: 3600 },
        removeOnFail: false,
      },
    }),
  };
  
  return queues;
};
```

WORKER TEMPLATE (example for Telegram):

```typescript
const createTelegramWorker = (redis: IORedis) => {
  return new Worker<NotificationJobData>(
    'notification:telegram',
    async (job) => {
      const { notificationId, deliveryAttemptId, channelPayload } = job.data;
      
      // Update status: processing
      await updateDeliveryStatus(deliveryAttemptId, 'processing');
      
      // Check system rate limit
      const allowed = await checkSystemRateLimit('telegram');
      if (!allowed) {
        throw new RateLimitError('System TPS limit reached for Telegram');
      }
      
      try {
        // Send via Telegram Bot API
        const result = await telegramClient.sendMessage({
          chat_id: channelPayload.chatId!,
          text: formatTelegramMessage(job.data),
          parse_mode: channelPayload.parseMode ?? 'HTML',
          reply_markup: buildActionButtons(job.data),
        });
        
        // Update status: sent
        await updateDeliveryStatus(deliveryAttemptId, 'sent', {
          providerMessageId: String(result.message_id),
          sentAt: new Date(),
          deliveryLatencyMs: Date.now() - job.timestamp,
        });
        
        // Reset consecutive failure counter
        await resetChannelFailures(job.data.userId, 'telegram');
        
        // Emit Prometheus metric
        notificationsSentCounter.inc({ channel: 'telegram', status: 'success' });
        
        return { success: true, messageId: result.message_id };
        
      } catch (err) {
        const errorType = classifyError(err);
        
        // Update delivery attempt with error details
        await updateDeliveryStatus(deliveryAttemptId, 'retrying', {
          errorType,
          errorMessage: err.message,
          errorCode: err.code,
          attemptNumber: job.attemptsMade + 1,
        });
        
        // Increment failure counter
        await incrementChannelFailures(job.data.userId, 'telegram');
        
        // Auto-disable channel after 10 consecutive failures
        const failures = await getConsecutiveFailures(job.data.userId, 'telegram');
        if (failures >= 10) {
          await autoDisableChannel(job.data.userId, 'telegram', errorType);
        }
        
        // Emit Prometheus metric
        notificationsSentCounter.inc({ channel: 'telegram', status: 'failed', error_type: errorType });
        
        throw err; // BullMQ handles retry based on config
      }
    },
    {
      connection: redis,
      concurrency: 10,  // Process 10 Telegram messages concurrently
      limiter: {
        max: 25,         // Max 25 jobs per second (under Telegram's 30/s limit)
        duration: 1000,
      },
      settings: {
        backoffStrategy: notificationBackoff,
      },
    },
  );
};
```

FAILED JOB LISTENER (cascade trigger):

```typescript
const setupCascadeListener = (redis: IORedis) => {
  const channels: NotificationChannel[] = ['push', 'telegram', 'whatsapp', 'email', 'sms'];
  
  for (const channel of channels) {
    const queueEvents = new QueueEvents(`notification:${channel}`, { connection: redis });
    
    queueEvents.on('failed', async ({ jobId, failedReason, prev }) => {
      const queue = new Queue(`notification:${channel}`, { connection: redis });
      const job = await queue.getJob(jobId);
      
      if (!job) return;
      
      // Check if this was the final retry attempt
      if (job.attemptsMade >= job.opts.attempts!) {
        // Mark delivery attempt as permanently failed
        await updateDeliveryStatus(job.data.deliveryAttemptId, 'failed', {
          failedAt: new Date(),
        });
        
        // Trigger cascade to next channel
        const errorType = classifyError(new Error(failedReason));
        await executeCascade(
          job.data.notificationId,
          job.data.userId,
          channel,
          errorType,
        );
      }
    });
  }
};
```

### 3.8 DELIVERY RECEIPT WEBHOOKS

WHATSAPP (Gupshup webhook):
```typescript
// POST /webhooks/whatsapp/status
app.post('/webhooks/whatsapp/status', async (c) => {
  const payload = await c.req.json();
  
  // Gupshup sends status updates: sent, delivered, read, failed
  const { messageId, status, timestamp } = parseGupshupWebhook(payload);
  
  const attempt = await findDeliveryAttemptByProviderMessageId(messageId);
  if (!attempt) return c.json({ ok: true }); // Ignore unknown messages
  
  const statusMap = {
    'sent': 'sent',
    'delivered': 'delivered',
    'read': 'read',
    'failed': 'failed',
  };
  
  await updateDeliveryStatus(attempt.id, statusMap[status], {
    [`${status}At`]: new Date(timestamp),
    deliveryLatencyMs: status === 'delivered'
      ? new Date(timestamp).getTime() - attempt.sentAt.getTime()
      : undefined,
  });
  
  // Track in PostHog
  posthog.capture({
    distinctId: attempt.userId,
    event: `notification_${status}`,
    properties: { channel: 'whatsapp', provider: 'gupshup', notification_id: attempt.notificationId },
  });
  
  return c.json({ ok: true });
});
```

TELEGRAM (Bot API update handler):
```typescript
// Telegram doesn't have delivery receipts, so we mark as "delivered" after successful send
// User actions tracked via callback_query (inline keyboard buttons)
app.post('/webhooks/telegram/callback', async (c) => {
  const update = await c.req.json();
  
  if (update.callback_query) {
    const { data, message } = update.callback_query;
    const [action, notificationId] = data.split(':');  // "mark_done:uuid" or "snooze:uuid"
    
    const attempt = await findDeliveryAttemptByNotificationId(notificationId, 'telegram');
    if (!attempt) return c.json({ ok: true });
    
    if (action === 'mark_done') {
      await markTaskComplete(attempt.taskId, 'notification');
      await updateDeliveryStatus(attempt.id, 'acted', {
        userAction: 'mark_done',
        userActionAt: new Date(),
      });
    } else if (action === 'snooze') {
      await snoozeTask(attempt.taskId, 30); // 30 minutes default
      await updateDeliveryStatus(attempt.id, 'acted', {
        userAction: 'snooze',
        userActionAt: new Date(),
      });
    }
    
    // Answer callback to remove loading state
    await telegramClient.answerCallbackQuery(update.callback_query.id, {
      text: action === 'mark_done' ? 'Task completed!' : 'Snoozed for 30 minutes',
    });
  }
  
  return c.json({ ok: true });
});
```

