    snackBarTheme: SnackBarThemeData(
      backgroundColor: UnjynxColors.surfaceContainerHighDark,
      behavior: SnackBarBehavior.floating,
      shape: RoundedRectangleBorder(borderRadius: UnjynxRadius.mdAll),
    ),
  );


